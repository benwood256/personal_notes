      align-items: center;       # centers items in the container vertically
   }

6. .container {
      display: grid;                           # creates Grid container
      grid-template-columns: repeat(2, 1fr);   # 2 items next to each other, each taking up 1 fraction of space (equal)
      gap: 20px;                               # 20 pixel gap between columns (i.e. 2 items next to each other, 20 pixels, 2 items, etc...)
   }


